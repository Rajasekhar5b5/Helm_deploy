pipeline {
  agent { label 'ns05-kube' }

  stages {

    stage('Checkout') {
      steps {
        git branch: 'main',
            credentialsId: 'ns05-github-cred',
            url: 'git@github.com:Rajasekhar5b5/Helm_deploy.git'
      }
    }

    stage('Check Workspace') {
      steps {
        sh '''
          pwd
          ls -la
          find . -maxdepth 3 -type f
        '''
      }
    }

    stage('Check Tools') {
      steps {
        sh '''
          helm version
          export KUBECONFIG=$HOME/k8s-3-node.conf
          kubectl get nodes
        '''
      }
    }

    stage('Deploy with Helm') {
      steps {
        sh '''
          export KUBECONFIG=$HOME/k8s-3-node.conf

          helm upgrade --install py-redis-release . \
            --namespace default

          kubectl rollout status deployment/py-deploy-ns05
          kubectl get pods
          kubectl get svc
          kubectl get deployments
        '''
      }
    }
  }
}